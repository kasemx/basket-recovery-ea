   BRE_LIVE_SAFETY_ACCOUNT_NOT_DEMO=12,
   BRE_LIVE_SAFETY_ACCOUNT_UNKNOWN=13,
   BRE_LIVE_SAFETY_ACCOUNT_TRADE_DISABLED=14,
   BRE_LIVE_SAFETY_TERMINAL_ALGO_DISABLED=15,
   BRE_LIVE_SAFETY_CHART_EA_TRADE_DISABLED=16,
   BRE_LIVE_SAFETY_BASKET_NOT_ACTIVE=17,
   BRE_LIVE_SAFETY_BASKET_LOCKED=18,
   BRE_LIVE_SAFETY_PROFILE_HASH_MISMATCH=19,
   BRE_LIVE_SAFETY_BASKET_VERSION_MISMATCH=20,
   BRE_LIVE_SAFETY_NOT_QUEUED_PREPARED=21,
   BRE_LIVE_SAFETY_ENVELOPE_EXPIRED=22,
   BRE_LIVE_SAFETY_STALE_QUOTE=23,
   BRE_LIVE_SAFETY_WIDE_SPREAD=24,
   BRE_LIVE_SAFETY_MARKET_UNAVAILABLE=25,
   BRE_LIVE_SAFETY_SYMBOL_CONSTRAINTS=26,
   BRE_LIVE_SAFETY_VOLUME_INVALID=27,
   BRE_LIVE_SAFETY_STOP_FREEZE_INVALID=28,
   BRE_LIVE_SAFETY_CONFLICTING_PENDING=29,
   BRE_LIVE_SAFETY_BASKET_RECONCILING_BLOCK=30,
   BRE_LIVE_SAFETY_DAILY_LOSS_GATE=31,
   BRE_LIVE_SAFETY_MAX_CONCURRENT_GATE=32,
   BRE_LIVE_SAFETY_EXECUTION_MODE_INVALID=33,
   BRE_LIVE_SAFETY_REQUEST_NOT_FOUND=34,
   BRE_LIVE_SAFETY_INTENT_NOT_ALLOWED=35,
   BRE_LIVE_SAFETY_VOLUME_EXCEEDS_DEMO_MAX=36,
