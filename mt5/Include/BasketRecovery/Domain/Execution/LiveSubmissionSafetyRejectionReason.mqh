enum ENUM_BRE_LIVE_SUBMISSION_SAFETY_REJECTION_REASON
  {
   BRE_LIVE_SAFETY_NONE=0,
   BRE_LIVE_SAFETY_LIVE_DISABLED=1,
   BRE_LIVE_SAFETY_GLOBAL_KILL_SWITCH=2,
   BRE_LIVE_SAFETY_BASKET_KILL_SWITCH=3,
   BRE_LIVE_SAFETY_DEMO_EXECUTION_DISABLED=4,
   BRE_LIVE_SAFETY_MANUAL_AUTH_REQUIRED=5,
   BRE_LIVE_SAFETY_TOKEN_MISSING=6,
